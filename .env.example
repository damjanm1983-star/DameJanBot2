# Binance Testnet Credentials
# Get these from: https://testnet.binancefuture.com/
export BINANCE_API_KEY="your_testnet_api_key_here"
export BINANCE_SECRET_KEY="your_testnet_secret_key_here"

# Trading Mode
export PAPER_MODE="true"

# Trading Settings
export SYMBOL="BTCUSDT"
export POSITION_ALLOCATION_PERCENT="0.50"
export TARGET_LEVERAGE="3"
export MAX_NOTIONAL_CAP_USDT="50000"

# Webhook Server
export WEBHOOK_PORT="8000"

